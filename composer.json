{
    "name": "mavidasnc/wp-health-check",
    "description": "Must-use plugin di monitoraggio flotta WordPress con self-update firmato. Repository di tooling dev; il plugin distribuito e' un file PHP singolo autoconsistente (mu-plugins/wp-health-check.php).",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpcsstandards/phpcsutils": "^1.0",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "phpstan/phpstan": "^1.11",
        "php-stubs/wordpress-stubs": "^6.4",
        "phpstan/extension-installer": "^1.4",
        "php-stubs/wp-cli-stubs": "^2.12"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "analyse": "phpstan analyse"
    }
}
